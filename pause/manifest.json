{
  "manifest_version": 3,
  "name": "Pause",
  "version": "0.3.0",
  "description": "A small pixel pet that lives on your new tab page. Says one gentle thing. Reminds you to pause.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["tabs", "storage"],
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
